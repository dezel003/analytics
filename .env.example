# Copy to .env (local) and set the same vars in the Vercel project settings.

# Neon Postgres connection string (pooled connection recommended for serverless).
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Secret salt mixed into the cookieless session hash. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRACK_SALT=change-me-to-a-long-random-string

# Password protecting the dashboard / stats endpoint.
DASHBOARD_PASSWORD=change-me
